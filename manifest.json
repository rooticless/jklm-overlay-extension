{
    "manifest_version": 3,
    "name": "JKLM Overlay",
    "version": "1.0.0",
    "description": "JKLM Overlay",
    "author": "Root",
    "permissions": [
        "activeTab",
        "storage",
        "tabs",
        "windows",
        "cookies"
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "host_permissions": [
        "https://jklm.fun/*",
        "https://www.jklm.fun/*",
        "https://rbqsegnrovayccfzwunb.supabase.co/*"
    ],
    "content_scripts": [
        {
            "matches": [
                "https://jklm.fun/*",
                "https://www.jklm.fun/*"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "content.css"
            ],
            "run_at": "document_idle"
        }
    ],
    "background": {
        "service_worker": "background.js"
    },
    "update_url": "https://rooticless.github.io/jklm-overlay-extension/updates.xml",
    "action": {
        "default_title": "JKLM Overlay",
        "default_popup": "profile.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    }
}
